# Configuração de Produção - NoteMusic Backend

NODE_ENV=production
PORT=3333

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/notemusic?retryWrites=true&w=majority

JWT_SECRET=<gere_um_secret_longo_e_aleatorio>
JWT_EXPIRES_IN=7d

CORS_ORIGINS=https://expo.dev
TRUST_PROXY=1
FRONTEND_URL=https://expo.dev

# Email (RECOMENDADO em Railway: Brevo via API HTTPS — 300/dia grátis, sem
# expirar). Railway bloqueia portas SMTP (25/465/587) nos planos Free/Trial/
# Hobby, então use a API, não o SMTP, para evitar timeout de conexão.
BREVO_API_KEY=<api_key_gerada_no_brevo_aba_API_Keys>
EMAIL_USER=<email_verificado_no_brevo>

# Brevo SMTP — só usar se estiver no plano Pro+ do Railway (ou fora do Railway)
# BREVO_SMTP_USER=<login_smtp_do_brevo>
# BREVO_SMTP_PASS=<smtp_key_gerada_no_brevo>

# SendGrid (legado, plano trial grátis expira em ~60 dias)
SENDGRID_API_KEY=<sua_chave_sendgrid>

# Segredos administrativos — obrigatórios em produção
ADMIN_SECRET=<secret_longo_aleatorio>
CACHE_CLEAR_SECRET=<pode_ser_o_mesmo_que_ADMIN_SECRET>

# Desafio diário semanal (cron no server)
# Com chave Gemini free: regenera enunciados toda segunda ~00h BRT
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
DAILY_WEEK_CRON=1
DAILY_WEEK_USE_GEMINI=1
