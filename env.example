PORT=3333
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/notemusic
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:8081
APP_NAME=NoteMusic

# Redefinição de senha — validade do código enviado por e-mail (minutos)
RESET_PASSWORD_EXPIRES_MIN=15

# Email — prioridade: Brevo API (HTTPS) > SendGrid (HTTPS) > Brevo SMTP > Gmail SMTP
#
# Brevo API (RECOMENDADO — obrigatório se hospedar em Railway Free/Trial/Hobby):
# o Railway bloqueia portas SMTP (25/465/587) nesses planos, então SMTP trava
# em timeout. A API HTTPS do Brevo não é bloqueada. Crie conta em
# https://app.brevo.com, verifique um remetente e gere a chave em
# Configurações > SMTP & API > aba "API Keys" (começa com "xkeysib-").
BREVO_API_KEY=

# Brevo SMTP (só funciona localmente ou no plano Pro+ do Railway).
# Gere em Configurações > SMTP & API > aba "SMTP" (começa com "xsmtpsib-").
BREVO_SMTP_USER=
BREVO_SMTP_PASS=

# SendGrid (legado): plano trial grátis perde os créditos após ~60 dias.
SENDGRID_API_KEY=

# EMAIL_USER = remetente verificado (usado como "from" em qualquer provedor).
# EMAIL_PASS = obrigatório só se for usar Gmail SMTP direto (Senha de app do Google).
EMAIL_USER=
EMAIL_PASS=

# Segredos administrativos (cache, reset de tentativas)
ADMIN_SECRET=your_admin_secret_here
CACHE_CLEAR_SECRET=

# Scripts de manutenção local (opcional)
DEV_USER_EMAIL=
DEV_USER_PASSWORD=
DEV_USER_NAME=
MASTER_EMAIL=
MASTER_PASSWORD=
MASTER_NAME=

# Usuários de teste local (npm run seed:test-users)
# notemusicaprendiz@gmail.com  / aprendiz123  (básico)
# notemusicvirtuoso@gmail.com  / virtuoso123  (intermediário)
# notemusicmaestro@gmail.com   / maestro123   (avançado/maestro)

# Sync local → produção (scripts/archive apenas)
MONGODB_URI_PRODUCTION=
