PORT=3333
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/notemusic
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:8081

# Email — produção: SENDGRID_API_KEY | dev local: EMAIL_USER + EMAIL_PASS
SENDGRID_API_KEY=
EMAIL_USER=
EMAIL_PASS=

# Segredos administrativos (cache, reset de tentativas)
ADMIN_SECRET=your_admin_secret_here
CACHE_CLEAR_SECRET=

# Scripts de manutenção local (opcional)
DEV_USER_EMAIL=
DEV_USER_PASSWORD=
DEV_USER_NAME=
MASTER_EMAIL=
MASTER_PASSWORD=
MASTER_NAME=

# Sync local → produção (scripts/archive apenas)
MONGODB_URI_PRODUCTION=
